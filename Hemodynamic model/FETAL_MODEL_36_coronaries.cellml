    <component name="Bif_DVin_FO1out_RA2out">
        <variable initial_value="0." name="Pi" public_interface="out" units="UnitP"/>
        <variable name="Po1" public_interface="in" units="UnitP"/>
        <variable name="Po2" public_interface="in" units="UnitP"/>
        <variable name="Qi" public_interface="in" units="UnitQ"/>
        <variable initial_value="0." name="Qo1" public_interface="out" units="UnitQ"/>
        <!--var Qo2: UnitQ {pub: out};-->
        <variable initial_value="0." name="Qo2" public_interface="out" units="UnitQ"/>
        <variable name="v1" public_interface="out" units="UnitVel"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="R1" public_interface="in" units="UnitR"/>
        <variable name="K1" public_interface="in" units="UnitK"/>
        <variable name="A1" public_interface="in" units="UnitA"/>
        <variable name="R2" public_interface="in" units="UnitR"/>
        <variable name="K2" public_interface="in" units="UnitK"/>
        <variable name="L" public_interface="in" units="UnitL"/>
        <variable name="Q0o1" public_interface="in" units="UnitQ"/>
        <!--ode(Qo1, t) = (Pi-Po1-R1*Qo1-K1*Qo1*abs(Qo1))/L;-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v1</ci>
                <apply>
                    <divide/>
                    <ci>Qo1</ci>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">0.7</cn>
                        <ci>A1</ci>
                    </apply>
                </apply>
            </apply>
            <!--Pi          = Po2+R2*Qo2+K2*Qo2*abs(Qo2);
Qo2         = Qi-Qo1;-->
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>Qo1</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <apply>
                                <minus/>
                                <ci>Pi</ci>
                                <ci>Po1</ci>
                            </apply>
                            <apply>
                                <times/>
                                <ci>R1</ci>
                                <ci>Qo1</ci>
                            </apply>
                        </apply>
                        <apply>
                            <times/>
                            <ci>K1</ci>
                            <ci>Qo1</ci>
                            <apply>
                                <abs/>
                                <ci>Qo1</ci>
                            </apply>
                        </apply>
                    </apply>
                    <ci>L</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>Qo2</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <apply>
                                <minus/>
                                <ci>Pi</ci>
                                <ci>Po2</ci>
                            </apply>
                            <apply>
                                <times/>
                                <ci>R2</ci>
                                <ci>Qo2</ci>
                            </apply>
                        </apply>
                        <apply>
                            <times/>
                            <ci>K2</ci>
                            <ci>Qo2</ci>
                            <apply>
                                <abs/>
                                <ci>Qo2</ci>
                            </apply>
                        </apply>
                    </apply>
                    <ci>L</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>Pi</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <ci>Qi</ci>
                            <ci>Qo1</ci>
                        </apply>
                        <ci>Qo2</ci>
                    </apply>
                    <cn cellml:units="UnitC">0.0005</cn>
                </apply>
            </apply>
        </math>
    </component>
    <component name="Bif_AOin_AO1out_INTE2out_HE3out_KID4out">
