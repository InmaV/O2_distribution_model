<?xml version='1.0' encoding='UTF-8'?>
<model cmeta:id="Main" name="Main" xmlns="http://www.cellml.org/cellml/1.0#" xmlns:cellml="http://www.cellml.org/cellml/1.0#" xmlns:cmeta="http://www.cellml.org/metadata/1.0#">
    <units name="UnitP">
        <unit multiplier="133" units="pascal"/>
    </units>
    <units name="UnitQ">
        <unit units="UnitV"/>
        <unit exponent="-1" units="second"/>
    </units>
    <units name="UnitVel">
        <unit units="UnitQ"/>
        <unit exponent="-1" multiplier="0.0001" units="meter"/>
    </units>
    <units name="UnitR">
        <unit units="UnitP"/>
        <unit exponent="-1" units="UnitQ"/>
    </units>
    <units name="UnitC">
        <unit exponent="-1" units="UnitP"/>
        <unit units="UnitV"/>
    </units>
    <units name="UnitK">
        <unit units="UnitP"/>
        <unit exponent="-2" units="UnitQ"/>
    </units>
    <units name="UnitKfo">
        <unit units="UnitP"/>
        <unit exponent="-0.625" units="UnitQ"/>
    </units>
    <units name="UnitL">
        <unit units="UnitP"/>
        <unit exponent="-1" units="UnitQ"/>
        <unit units="second"/>
    </units>
    <units name="UnitV">
        <unit multiplier="0.001" units="litre"/>
    </units>
    <units name="UnitE">
        <unit exponent="-1" units="UnitC"/>
    </units>
    <units name="Unitl">
        <unit multiplier="1e-06" units="meter"/>
    </units>
    <units name="UnitA">
        <unit exponent="2" multiplier="0.01" units="meter"/>
    </units>
    <units name="Unitc">
        <unit exponent="-1" multiplier="0.01" units="meter"/>
    </units>
    <units name="UnitT">
        <unit units="UnitP"/>
        <unit multiplier="0.01" units="meter"/>
    </units>
    <units name="Unitv">
        <unit units="Unitl"/>
        <unit exponent="-1" units="second"/>
    </units>
    <units name="UnitKxi">
        <unit exponent="-1" units="UnitP"/>
        <unit exponent="-1" units="second"/>
    </units>
    <units name="UnitLparam">
        <unit units="UnitL"/>
        <unit units="UnitA"/>
    </units>
    <units name="UnitB">
        <unit units="UnitP"/>
        <unit exponent="-2" units="UnitQ"/>
        <unit exponent="2" units="second"/>
    </units>
    <units name="UnitBparam">
        <unit units="UnitB"/>
        <unit units="UnitA"/>
    </units>
    <units name="ode_s">
        <unit exponent="-1" units="second"/>
    </units>
    <component name="environment">
        <variable name="t" public_interface="out" units="second"/>
    </component>
    <component name="LA">
        <variable name="L" units="dimensionless"/>
        <variable name="Ls" units="Unitl"/>
        <variable name="Lsref" public_interface="in" units="Unitl"/>
        <variable initial_value="2." name="Lsc" public_interface="out" units="Unitl"/>
        <variable name="Lscini" public_interface="in" units="Unitl"/>
        <variable name="Lsnorm" units="dimensionless"/>
        <variable name="ta" units="second"/>
        <variable name="tact" units="second"/>
        <variable name="td" units="second"/>
        <variable name="trise" units="second"/>
        <variable name="p_tact" public_interface="in" units="second"/>
        <variable name="p_trise" public_interface="in" units="dimensionless"/>
        <variable name="p_td" public_interface="in" units="dimensionless"/>
        <variable initial_value="0.0" name="C" public_interface="out" units="dimensionless"/>
        <variable name="C0" public_interface="in" units="dimensionless"/>
        <variable initial_value="23.5" name="Vcav" public_interface="out" units="UnitV"/>
        <variable name="Vcav0" public_interface="in" units="UnitV"/>
        <variable name="Vwall" public_interface="in" units="UnitV"/>
        <variable name="sfpas" units="UnitP"/>
        <variable name="sfact" units="UnitP"/>
        <variable name="sfrest" units="UnitP"/>
        <variable name="sf" units="UnitP"/>
        <variable name="spas" public_interface="in" units="UnitP"/>
        <variable name="sact" public_interface="in" units="UnitP"/>
        <variable name="vmax" public_interface="in" units="Unitv"/>
        <variable name="delay" public_interface="in" units="second"/>
        <variable name="Time" units="second"/>
        <variable name="Time2" units="second"/>
        <variable name="xrise" units="dimensionless"/>
        <variable name="fRise" units="dimensionless"/>
        <variable name="fDecay" units="dimensionless"/>
        <variable name="Crest" public_interface="in" units="dimensionless"/>
        <variable name="xPos" units="dimensionless"/>
        <variable name="xSarc" units="dimensionless"/>
        <variable name="y" units="dimensionless"/>
        <variable name="NoBuckle" units="dimensionless"/>
        <variable name="Vm" units="UnitV"/>
        <variable name="Cm" units="Unitc"/>
        <variable name="Am" units="UnitA"/>
        <variable name="Amtotal" units="UnitA"/>
        <variable name="Amdead" public_interface="in" units="UnitA"/>
        <variable name="Amref" public_interface="in" units="UnitA"/>
        <variable name="z" public_interface="out" units="dimensionless"/>
        <variable name="Ef" units="dimensionless"/>
        <variable name="kS" public_interface="in" units="dimensionless"/>
        <variable name="Tension" units="UnitT"/>
        <variable name="Pi" public_interface="out" units="UnitP"/>
        <variable name="Po" public_interface="in" units="UnitP"/>
        <variable name="Qi" public_interface="in" units="UnitQ"/>
        <variable initial_value="0." name="Qo" public_interface="out" units="UnitQ"/>
        <variable name="Q0" public_interface="in" units="UnitQ"/>
        <variable name="T" public_interface="in" units="second"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="Kvo" public_interface="in" units="UnitKxi"/>
        <variable name="Kvc_p" public_interface="in" units="UnitKxi"/>
        <variable name="Kvc_n" public_interface="in" units="UnitKxi"/>
        <variable name="Linductance" units="UnitL"/>
        <variable name="L_min" public_interface="in" units="UnitL"/>
        <variable name="L_param" public_interface="in" units="UnitLparam"/>
        <variable initial_value="1.0" name="xi" units="dimensionless"/>
        <variable name="Aeff" units="UnitA"/>
        <variable name="Aann" public_interface="in" units="UnitA"/>
        <variable name="B" units="UnitB"/>
        <variable name="val_xi" units="ode_s"/>
        <variable name="B_param" public_interface="in" units="UnitBparam"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>tact</ci>
                <ci>p_tact</ci>
            </apply>
            <apply>
                <eq/>
                <ci>td</ci>
                <apply>
                    <times/>
                    <ci>p_td</ci>
                    <ci>tact</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>trise</ci>
                <apply>
                    <times/>
                    <ci>p_trise</ci>
                    <ci>tact</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>ta</ci>
                <apply>
                    <times/>
                    <ci>tact</ci>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">0.65</cn>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">0.7</cn>
                            <ci>L</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Time</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <ci>t</ci>
                            <ci>delay</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>T</ci>
                            <apply>
                                <floor/>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <minus/>
                                        <ci>t</ci>
                                        <ci>delay</ci>
                                    </apply>
                                    <ci>T</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <ci>trise</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>xrise</ci>
                <apply>
                    <min/>
                    <cn cellml:units="dimensionless">8</cn>
                    <apply>
                        <max/>
                        <ci>Time</ci>
                        <cn cellml:units="dimensionless">0</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>fRise</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <apply>
                            <tanh/>
                            <apply>
                                <times/>
                                <cn cellml:units="dimensionless">4.0</cn>
                                <apply>
                                    <power/>
                                    <ci>L</ci>
                                    <cn cellml:units="dimensionless">2</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <ci>xrise</ci>
                            <cn cellml:units="dimensionless">3</cn>
                        </apply>
                        <apply>
                            <exp/>
                            <apply>
                                <minus/>
                                <ci>xrise</ci>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">8</cn>
                                <ci>xrise</ci>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <cn cellml:units="dimensionless">0.020</cn>
                    </apply>
                    <ci>trise</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Time2</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <apply>
                                <minus/>
                                <ci>t</ci>
                                <ci>delay</ci>
                            </apply>
                            <apply>
                                <times/>
                                <ci>T</ci>
                                <apply>
                                    <floor/>
                                    <apply>
                                        <divide/>
                                        <apply>
                                            <minus/>
                                            <ci>t</ci>
                                            <ci>delay</ci>
                                        </apply>
                                        <ci>T</ci>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                        <ci>ta</ci>
                    </apply>
                    <ci>td</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>fDecay</ci>
                <apply>
                    <divide/>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">0.5</cn>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">0.5</cn>
                            <apply>
                                <sin/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <divide/>
                                        <ci>Time2</ci>
                                        <apply>
                                            <abs/>
                                            <ci>Time2</ci>
                                        </apply>
                                    </apply>
                                    <apply>
                                        <min/>
                                        <apply>
                                            <divide/>
                                            <pi/>
                                            <cn cellml:units="dimensionless">2</cn>
                                        </apply>
                                        <apply>
                                            <abs/>
                                            <ci>Time2</ci>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <ci>td</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>fRise</ci>
                    <apply>
                        <times/>
                        <ci>C</ci>
                        <ci>fDecay</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>sfact</ci>
                <apply>
                    <times/>
                    <ci>sact</ci>
                    <ci>C</ci>
                    <ci>L</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>sfrest</ci>
                <apply>
                    <times/>
                    <ci>sact</ci>
                    <ci>Crest</ci>
                    <ci>L</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>xPos</ci>
                <apply>
                    <max/>
                    <apply>
                        <times/>
                        <ci>kS</ci>
                        <apply>
                            <ln/>
                            <apply>
                                <divide/>
                                <ci>Ls</ci>
                                <cn cellml:units="Unitl">1.8</cn>
                            </apply>
                        </apply>
                    </apply>
                    <cn cellml:units="dimensionless">0</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>xSarc</ci>
                <apply>
                    <plus/>
                    <apply>
                        <ln/>
                        <apply>
                            <divide/>
                            <ci>Ls</ci>
                            <ci>Lsref</ci>
                        </apply>
                    </apply>
                    <cn cellml:units="dimensionless">0.1</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>y</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">0.12</cn>
                        <apply>
                            <minus/>
                            <apply>
                                <cosh/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">5</cn>
                                    <ci>xPos</ci>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </apply>
                    <ci>xSarc</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>sfpas</ci>
                <apply>
                    <times/>
                    <ci>spas</ci>
                    <ci>y</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>NoBuckle</ci>
                <apply>
                    <tanh/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">10</cn>
                            <ci>C</ci>
                        </apply>
                        <apply>
                            <max/>
                            <cn cellml:units="dimensionless">0</cn>
                            <apply>
                                <times/>
                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>-4</cn>
                                <apply>
                                    <power/>
                                    <ci>sfpas</ci>
                                    <cn cellml:units="dimensionless">2</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>sf</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <max/>
                            <apply>
                                <times/>
                                <cn cellml:units="dimensionless">0.2</cn>
                                <ci>sfpas</ci>
                            </apply>
                            <ci>sfpas</ci>
                        </apply>
                        <apply>
                            <times/>
                            <apply>
                                <plus/>
                                <ci>sfact</ci>
                                <ci>sfrest</ci>
                            </apply>
                            <ci>Lsnorm</ci>
                        </apply>
                    </apply>
                    <ci>sfrest</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Ls</ci>
                <apply>
                    <times/>
                    <apply>
                        <exp/>
                        <ci>Ef</ci>
                    </apply>
                    <ci>Lsref</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>L</ci>
                <apply>
                    <max/>
                    <apply>
                        <divide/>
                        <apply>
                            <minus/>
                            <ci>Lsc</ci>
                            <cn cellml:units="Unitl">1.51</cn>
                        </apply>
                        <cn cellml:units="Unitl">1</cn>
                    </apply>
                    <cn cellml:units="dimensionless">0.0001</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Lsnorm</ci>
                <apply>
                    <max/>
                    <apply>
                        <divide/>
                        <apply>
                            <minus/>
                            <ci>Ls</ci>
                            <ci>Lsc</ci>
                        </apply>
                        <cn cellml:units="Unitl">0.04</cn>
                    </apply>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">0.02</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>Lsc</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <apply>
                            <max/>
                            <apply>
                                <minus/>
                                <ci>Lsnorm</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <times/>
                                <ci>NoBuckle</ci>
                                <apply>
                                    <minus/>
                                    <ci>Lsnorm</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                        </apply>
                        <ci>vmax</ci>
                        <cn cellml:units="second">0.85</cn>
                    </apply>
                    <ci>T</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Vm</ci>
                <apply>
                    <plus/>
                    <ci>Vcav</ci>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">0.5</cn>
                        <ci>Vwall</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Cm</ci>
                <apply>
                    <power/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">4</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">3</cn>
                            <ci>Vm</ci>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <cn cellml:units="dimensionless">3</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Amtotal</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">4</cn>
                        <pi/>
                    </apply>
                    <apply>
                        <power/>
                        <ci>Cm</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Am</ci>
                <apply>
                    <minus/>
                    <ci>Amtotal</ci>
                    <ci>Amdead</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>z</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">1.5</cn>
                        <ci>Vwall</ci>
                        <ci>Cm</ci>
                    </apply>
                    <ci>Am</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Ef</ci>
                <apply>
                    <minus/>
                    <apply>
                        <minus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">0.5</cn>
                            <apply>
                                <ln/>
                                <apply>
                                    <divide/>
                                    <ci>Am</ci>
                                    <ci>Amref</ci>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <divide/>
                            <apply>
                                <power/>
                                <ci>z</ci>
                                <cn cellml:units="dimensionless">2</cn>
                            </apply>
                            <cn cellml:units="dimensionless">12</cn>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">0.019</cn>
                        <apply>
                            <power/>
                            <ci>z</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Tension</ci>
                <apply>
                    <times/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>sf</ci>
                            <cn cellml:units="dimensionless">0.5</cn>
                            <apply>
                                <plus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">0.27</cn>
                                    <apply>
                                        <power/>
                                        <ci>z</ci>
                                        <cn cellml:units="dimensionless">2</cn>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                        <ci>Am</ci>
                    </apply>
                    <ci>Vwall</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Pi</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>Tension</ci>
                    <ci>Cm</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>Vcav</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>Qi</ci>
                    <ci>Qo</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>Qo</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <ci>Pi</ci>
                            <ci>Po</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>B</ci>
                            <ci>Qo</ci>
                            <apply>
                                <abs/>
                                <ci>Qo</ci>
                            </apply>
                        </apply>
                    </apply>
                    <ci>Linductance</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Linductance</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>L_param</ci>
                        <ci>Aeff</ci>
                    </apply>
                    <ci>L_min</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>B</ci>
                <apply>
                    <divide/>
                    <ci>B_param</ci>
                    <apply>
                        <power/>
                        <ci>Aeff</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Aeff</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>Aann</ci>
                        <ci>xi</ci>
                    </apply>
                    <cn cellml:units="UnitA">0.0001</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>xi</ci>
                </apply>
                <piecewise>
                    <piece>
                        <apply>
                            <times/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>xi</ci>
                            </apply>
                            <ci>Kvo</ci>
                            <apply>
                                <minus/>
                                <ci>Pi</ci>
                                <ci>Po</ci>
                            </apply>
                        </apply>
                        <apply>
                            <geq/>
                            <ci>Pi</ci>
                            <ci>Po</ci>
                        </apply>
                    </piece>
                    <otherwise>
                        <ci>val_xi</ci>
                    </otherwise>
                </piecewise>
            </apply>
            <apply>
