    <component name="Bif_DV1in_IVC2in_FOout">
        <variable name="Po" public_interface="in" units="UnitP"/>
        <variable initial_value="0." name="Pi1" public_interface="out" units="UnitP"/>
        <variable name="Pi2" public_interface="out" units="UnitP"/>
        <variable initial_value="0." name="Qo" public_interface="out" units="UnitQ"/>
        <variable name="Qi1" public_interface="in" units="UnitQ"/>
        <variable name="Qi2" public_interface="in" units="UnitQ"/>
        <variable initial_value="0" name="V" units="UnitV"/>
        <variable name="v1" public_interface="in" units="UnitVel"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="K" public_interface="in" units="UnitKfo"/>
        <variable name="C1" public_interface="in" units="UnitC"/>
        <variable name="C2" public_interface="in" units="UnitC"/>
        <variable name="Q0o" public_interface="in" units="UnitQ"/>
        <variable name="P0i1" public_interface="in" units="UnitQ"/>
        <variable name="P0i2" public_interface="in" units="UnitQ"/>
        <variable name="Kvo" public_interface="in" units="UnitKxi"/>
        <variable name="Kvc_p" public_interface="in" units="UnitKxi"/>
        <variable name="Kvc_n" public_interface="in" units="UnitKxi"/>
        <variable name="Linductance" units="UnitL"/>
        <variable name="L_min" public_interface="in" units="UnitL"/>
        <variable name="L_param" public_interface="in" units="UnitLparam"/>
        <variable initial_value="1.0" name="xi" units="dimensionless"/>
        <variable name="val_xi" units="ode_s"/>
        <variable name="Aeff" units="UnitA"/>
        <variable name="Aann" public_interface="in" units="UnitA"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>V</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <ci>Qi1</ci>
                        <ci>Qi2</ci>
                    </apply>
                    <ci>Qo</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>Pi1</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <apply>
                            <plus/>
                            <ci>Qi1</ci>
                            <ci>Qi2</ci>
                        </apply>
                        <ci>Qo</ci>
                    </apply>
                    <ci>C1</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Pi2</ci>
                <ci>Pi1</ci>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>Qo</ci>
                </apply>
                <piecewise>
                    <piece>
                        <apply>
                            <divide/>
                            <apply>
                                <minus/>
                                <apply>
                                    <minus/>
                                    <ci>Pi1</ci>
                                    <ci>Po</ci>
                                </apply>
                                <apply>
                                    <times/>
                                    <apply>
                                        <divide/>
                                        <ci>K</ci>
                                        <ci>Aeff</ci>
                                    </apply>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <abs/>
                                            <ci>Qo</ci>
                                        </apply>
                                        <cn cellml:units="dimensionless">0.625</cn>
                                    </apply>
                                </apply>
                            </apply>
                            <ci>Linductance</ci>
                        </apply>
                        <apply>
                            <geq/>
                            <ci>Qo</ci>
                            <cn cellml:units="dimensionless">0</cn>
                        </apply>
                    </piece>
                    <otherwise>
                        <apply>
                            <divide/>
                            <apply>
                                <plus/>
                                <apply>
                                    <minus/>
                                    <ci>Pi1</ci>
                                    <ci>Po</ci>
                                </apply>
                                <apply>
                                    <times/>
                                    <apply>
                                        <divide/>
                                        <ci>K</ci>
                                        <ci>Aeff</ci>
                                    </apply>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <abs/>
                                            <ci>Qo</ci>
                                        </apply>
                                        <cn cellml:units="dimensionless">0.625</cn>
                                    </apply>
                                </apply>
                            </apply>
                            <ci>Linductance</ci>
                        </apply>
                    </otherwise>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>Linductance</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>L_param</ci>
                        <ci>Aeff</ci>
                    </apply>
                    <ci>L_min</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Aeff</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>Aann</ci>
                        <ci>xi</ci>
                    </apply>
                    <cn cellml:units="UnitA">0.0001</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>xi</ci>
                </apply>
                <piecewise>
                    <piece>
                        <apply>
                            <times/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>xi</ci>
                            </apply>
                            <ci>Kvo</ci>
                            <apply>
                                <minus/>
                                <ci>Pi1</ci>
                                <ci>Po</ci>
                            </apply>
                        </apply>
                        <apply>
                            <geq/>
                            <ci>Pi1</ci>
                            <ci>Po</ci>
                        </apply>
                    </piece>
                    <otherwise>
                        <ci>val_xi</ci>
                    </otherwise>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>val_xi</ci>
                <piecewise>
                    <piece>
                        <apply>
                            <times/>
                            <ci>xi</ci>
                            <ci>Kvc_p</ci>
                            <apply>
                                <minus/>
                                <ci>Pi1</ci>
                                <ci>Po</ci>
                            </apply>
                        </apply>
                        <apply>
                            <geq/>
                            <apply>
                                <plus/>
                                <ci>Qi1</ci>
                                <ci>Qi2</ci>
                            </apply>
                            <ci>Qo</ci>
                        </apply>
                    </piece>
                    <otherwise>
                        <apply>
                            <times/>
                            <ci>xi</ci>
                            <ci>Kvc_n</ci>
                            <apply>
                                <minus/>
                                <ci>Pi1</ci>
                                <ci>Po</ci>
                            </apply>
                        </apply>
                    </otherwise>
                </piecewise>
            </apply>
        </math>
    </component>
