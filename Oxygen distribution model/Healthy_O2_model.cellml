    <component name="LA">
        <variable name="cO2i" public_interface="in" units="dimensionless"/>
        <variable initial_value="0" name="cO2o" public_interface="out" units="dimensionless"/>
        <variable name="alpha" public_interface="in" units="UnitAlpha"/>
        <variable name="beta" public_interface="in" units="UnitBeta"/>
