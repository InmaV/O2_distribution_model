                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>pO2</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <divide/>
                        <apply>
                            <minus/>
                            <ci>cO2o</ci>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <ci>alpha</ci>
                                    <ci>Hb</ci>
                                    <ci>SO2</ci>
                                </apply>
                                <cn cellml:units="dimensionless">100</cn>
                            </apply>
                        </apply>
                        <ci>beta</ci>
                    </apply>
                    <ci>pO2</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>SO2</ci>
                <apply>
                    <divide/>
                    <cn cellml:units="dimensionless">100</cn>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <divide/>
                            <ci>c1</ci>
                            <apply>
                                <plus/>
                                <apply>
                                    <power/>
                                    <ci>pO2</ci>
                                    <cn cellml:units="dimensionless">3</cn>
                                </apply>
                                <apply>
