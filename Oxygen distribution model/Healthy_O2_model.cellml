        <variable name="SO2" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>cO2o</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>cO2i</ci>
                    <ci>cO2o</ci>
                </apply>
            </apply>
            <apply>
